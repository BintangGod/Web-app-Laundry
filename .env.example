# 🧺 Bintang Laundry Contact Configuration Example
# Salin file ini menjadi .env.local dan sesuaikan dengan data laundry Anda.

# 📞 Kontak & WhatsApp (Ganti dengan nomor WhatsApp aktif)
NEXT_PUBLIC_CONTACT_PHONE=081234567890
NEXT_PUBLIC_CONTACT_PHONE_WA=6281234567890
NEXT_PUBLIC_WA_MESSAGE=Halo Bintang Laundry, saya ingin memesan layanan laundry. Apakah bisa antar jemput?
NEXT_PUBLIC_INSTAGRAM_USERNAME=@bintanglaundry.btr
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/bintanglaundry.btr?igsh=MTZmcmNvcWNoZmJxZA==

# 📍 Alamat & Google Maps
NEXT_PUBLIC_ADDRESS_LINE1=Cluster Corundum Blok C2 No. 5
NEXT_PUBLIC_ADDRESS_LINE2=Cimuning, Mustika Jaya
NEXT_PUBLIC_ADDRESS_CITY=Bekasi
NEXT_PUBLIC_ADDRESS_PROVINCE=Jawa Barat
NEXT_PUBLIC_MAPS_URL=https://maps.app.goo.gl/6vK6ZBzACq612nZFA
